# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890
CALL_TO_NUMBER=+1234567890

# Discord Bot
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_COOLDOWN_MS=300000
DISCORD_CHANNEL_ID=   # optional: leave empty for all channels

# Telegram Tracker
TELEGRAM_API_ID=       # from my.telegram.org
TELEGRAM_API_HASH=     # from my.telegram.org
TELEGRAM_SESSION=      # generated by: npm run telegram:auth
TELEGRAM_CHANNEL_ID=   # optional: leave empty for all channels
TELEGRAM_COOLDOWN_MS=300000

# Call Provider: twilio, telnyx, or sip (free)
CALL_PROVIDER=sip

# Telnyx (only needed if CALL_PROVIDER=telnyx or for SMS)
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_PHONE_NUMBER=
TELNYX_WEBHOOK_URL=              # public URL of this server, e.g. https://abc.ngrok.io
TELNYX_MESSAGING_PROFILE_ID=    # optional: from Telnyx portal > Messaging > Profiles

# SIP Calling (free — rings Linphone iOS app via push notification, no account needed)
# How it works: sends a SIP INVITE to sip.linphone.org which pushes to the Linphone app
# Setup: install Linphone on iPhone, create account ericle@sip.linphone.org, stay logged in
SIP_BOT_USER=alertbot            # any username (not a real account — just identifies the caller)
SIP_BOT_DOMAIN=iptel.org         # any external SIP domain (not sip.linphone.org)
SIP_TARGET_USER=ericle           # your Linphone username on sip.linphone.org
SIP_TARGET_DOMAIN=sip.linphone.org
SIP_RING_DURATION_MS=30000       # how long to ring before auto hang-up (ms)
