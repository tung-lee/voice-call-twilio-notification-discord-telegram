{
  "name": "voice-call-twilio-notification",
  "version": "1.0.0",
  "description": "Discord bot + Twilio voice call notification server",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "pm2:start": "npm run build && pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "npm run build && pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs voice-call-twilio-notification",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "telegram:auth": "tsx src/scripts/telegram-auth.ts"
  },
  "keywords": [
    "twilio",
    "discord",
    "voice",
    "notification"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "input": "^1.0.1",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "telegram": "^2.26.22",
    "telnyx": "^6.58.0",
    "twilio": "^5.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
